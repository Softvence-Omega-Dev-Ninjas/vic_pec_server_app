model Canine {
  id                String              @id @default(uuid())

  // ID separation for better management
  pcrId            String   @unique // e.g., PCR-G301-00001-123456
  // ID Components
  pcrPrefix        String   // 'G' or 'B'
  pcrBreedCode     String   // '301'
  generation       String?  // 'F1', 'F1B'
  pcrIncremental   String   // '00001'
  pcrRandom        String   // '123456'

  // Relations
  breedId          String
  breedRelation    Breed    @relation(fields: [breedId], references: [id])


  name              String
  gender            Gender
  dateOfBirth       DateTime
  color             String
  weight            Float
  city              String
  state             String
  zipCode           String
  country           String
  microchipId       String             @unique
  primaryBreedDNA   String
  secondaryBreedDNA String?
  healthStatus      String              @default("Excellent")
  vaccinations      VaccinationType[]
  healthClearances  HealthClearance[]
  healthNotes       String?             @db.Text

  images            Image[]             @relation("CanineImages")
  DNAdocuments      Document[]          @relation("CanineDocuments")
  transfers         OwnershipTransfer[] @relation("CanineTransfers")

  // Owner Relation
  ownerId           String
  owner             User                @relation("UserCanines", fields: [ownerId], references: [id])

  // Litter Relation
  litterId          String?
  litter            Litter?             @relation("LitterPuppies", fields: [litterId], references: [id], onDelete: Cascade)

  // Pedigree History
  asMother          Litter[]            @relation("MotherRelation")
  asFather          Litter[]            @relation("FatherRelation")

  reports     Report[] @relation("CanineReports")


  requestType       RegistrationRequestType         @default(NEW_REGISTRATION)
  status            CertificateRequestStatus       @default(PENDING) 
  assignedTier      VerificationType    @default(NONE)  

  certificateRequests CertificateRequest[] @relation("CanineCertRequests") 

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("canines")
}
