model User {
  id                    String              @id @default(uuid())
  email                 String              @unique

  pcrId            String   @unique // e.g., PCR-OW0001-123456
  
  pcrPrefix        String   // 'OW' or 'PA'
  pcrIncremental   String   // '0001'
  pcrRandom        String   // '123456'


  password              String
  phoneNumber           String?
  ownershipTransferCode String?

  otp             String?   
  otpExpires      DateTime?
  otpAttempts     Int       @default(0)  
  otpLockUntil    DateTime?

  fullName              String?
  about                 String?             @db.Text
  isVerified            Boolean             @default(false)
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  status    UserStatus @default(PENDING)

  // Profile Media
  profileImage          Image?              @relation("UserProfileImage")
  coverImage            Image?              @relation("UserCoverImage")

  // Settings
  emailNotifications    Boolean             @default(true)
  showOwnerId           Boolean             @default(true)

  // Ownership Transfers
  sentTransfers         OwnershipTransfer[] @relation("SentTransfers")
  receivedTransfers     OwnershipTransfer[] @relation("ReceivedTransfers")

  // Membership & Role
  membershipId          String?
  membership            Membership?          @relation(fields: [membershipId], references: [id])
  roleType              RoleType            @default(USER)
  permissions           AccessPermission[]

  // Relation to Canine & Litter
  canines               Canine[]            @relation("UserCanines")
  ownedLitters          Litter[]            @relation("LitterOwner")

  reportedIssues Report[] @relation("UserReports")

  certificateRequests CertificateRequest[] @relation("UserCertRequests")

  subscriptions     Subscription[]

  lastLogin             DateTime?           @default(now())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@map("users")
}


model AccessPermission {
  id          String       @id @default(uuid())
  resource    ResourceType 
  
  canView     Boolean      @default(false)
  canCreate   Boolean      @default(false)
  canEdit     Boolean      @default(false)
  canDelete   Boolean      @default(false)

  // Relation to User
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resource])
  @@map("access_permissions")
}


















model Membership {
  id            String         @id @default(uuid())
  tier          String         @unique 
  name          String
  currentPrice  Float          @default(0)
  stripePriceId String?        @unique 
  features      Json?
  canineLimit   Int            @default(1)
  
  users         User[]
  subscriptions Subscription[]
  @@map("memberships")
}

model Subscription {
  id                   String   @id @default(uuid())
  stripeSubscriptionId String   @unique
  userId               String
  user                 User     @relation(fields: [userId], references: [id])
  membershipId         String
  membership           Membership @relation(fields: [membershipId], references: [id])

  amountPaid           Float   
  currency             String   @default("USD")
  status               String   // active, canceled, past_due
  
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  
  createdAt            DateTime @default(now())
  @@map("subscriptions")
}